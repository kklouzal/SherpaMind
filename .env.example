# Canonical SherpaDesk API docs:
# https://github.com/sherpadesk/api/wiki

# Optional workspace root override. Defaults to the OpenClaw workspace parent
# when installed under an OpenClaw skills directory, otherwise to the current
# working directory. SherpaMind creates/uses .SherpaMind/ under this root.
SHERPAMIND_WORKSPACE_ROOT=

# Optional direct runtime-root override for moved/reinstalled skills.
# Set this to an existing .SherpaMind directory when runtime data already lives
# somewhere other than the current install/workspace root.
SHERPAMIND_ROOT=

# SherpaDesk connection settings
# Normal live installs configure SHERPADESK_API_KEY and alert delivery through
# the OpenClaw `sherpamind` skill entry. Org/instance settings are staged under
# `.SherpaMind/private/config/settings.env`; optional API-user hints come from
# environment variables or OpenClaw-managed config.
# This file documents optional override keys and defaults.
SHERPADESK_API_BASE_URL=https://api.sherpadesk.com
SHERPADESK_API_KEY=
SHERPADESK_API_USER=
SHERPADESK_ORG_KEY=
SHERPADESK_INSTANCE_KEY=

# Local storage is managed under `.SherpaMind/` by default.
# Main staged/runtime directories are:
# - .SherpaMind/private/config/
# - .SherpaMind/private/data/
# - .SherpaMind/private/state/
# - .SherpaMind/private/logs/
# - .SherpaMind/private/runtime/
# - .SherpaMind/public/

# OpenClaw alert delivery posts to authenticated POST /hooks/agent.
# When SherpaMind runs on the same host as OpenClaw and hooks are enabled,
# hook URL/token default from ~/.openclaw/openclaw.json (hooks.path + hooks.token).
# Enablement and destination are configured as first-class OpenClaw skill fields:
# skills.entries.sherpamind.config.newTicketAlertsEnabled
# skills.entries.sherpamind.config.ticketUpdateAlertsEnabled
# skills.entries.sherpamind.config.newTicketAlertChannel
# skills.entries.sherpamind.config.ticketUpdateAlertChannel
SHERPAMIND_OPENCLAW_WEBHOOK_URL=http://127.0.0.1:18789/hooks/agent
SHERPAMIND_OPENCLAW_WEBHOOK_TOKEN=

# Conservative request behavior for a fragile/awkward API
# SherpaDesk docs note a limit of 600 requests/hour, so keep the default deliberately slow.
SHERPAMIND_REQUEST_MIN_INTERVAL_SECONDS=8.0
SHERPAMIND_REQUEST_TIMEOUT_SECONDS=30.0

# Seed controls
SHERPAMIND_SEED_PAGE_SIZE=100
# Leave blank for full seed; set a small number during cautious testing.
SHERPAMIND_SEED_MAX_PAGES=

# Delta lane controls
SHERPAMIND_HOT_OPEN_PAGES=5
SHERPAMIND_WARM_CLOSED_PAGES=10
SHERPAMIND_WARM_CLOSED_DAYS=7
SHERPAMIND_COLD_CLOSED_PAGES_PER_RUN=2
