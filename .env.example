# Canonical SherpaDesk API docs:
# https://github.com/sherpadesk/api/wiki

# SherpaDesk API
SHERPADESK_API_BASE_URL=https://api.sherpadesk.com
SHERPADESK_API_KEY=
SHERPADESK_API_USER=
SHERPADESK_ORG_KEY=
SHERPADESK_INSTANCE_KEY=

# Local storage
SHERPAMIND_DB_PATH=state/sherpamind.sqlite3

# Watcher state
SHERPAMIND_WATCH_STATE_PATH=state/watch_state.json

# Optional notification target (fill in once chosen)
SHERPAMIND_NOTIFY_CHANNEL=

# Conservative request behavior for a fragile/awkward API
# SherpaDesk docs note a limit of 600 requests/hour, so keep the default deliberately slow.
SHERPAMIND_REQUEST_MIN_INTERVAL_SECONDS=8.0
SHERPAMIND_REQUEST_TIMEOUT_SECONDS=30.0

# Seed controls
SHERPAMIND_SEED_PAGE_SIZE=100
# Leave blank for full seed; set a small number during cautious testing.
SHERPAMIND_SEED_MAX_PAGES=

# Delta lane controls
SHERPAMIND_HOT_OPEN_PAGES=5
SHERPAMIND_WARM_CLOSED_PAGES=10
SHERPAMIND_WARM_CLOSED_DAYS=7
SHERPAMIND_COLD_CLOSED_PAGES_PER_RUN=2
